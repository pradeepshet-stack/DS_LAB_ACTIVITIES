Friday Lab Evaluation
The Indian Space Research Organisation (ISRO) conducts an annual evaluation of its satellite missions to analyze mission success and technological performance.
To improve mission planning and data management, ISRO plans to develop a system that efficiently stores and analyzes satellite information.
The system should:
1. Read the details of N satellites.
2. Display all entered satellite records in a structured format.
3. Include a separate function to identify and display the satellite with the highest mission success rate.
4. Include another function to display the details of satellite(s) launched in the year 2015.
5. Use structures and dynamic memory allocation to manage the data.
6. Students are required to identify suitable data members and implement necessary functions.

✅ C Program Using Structures & Dynamic Memory Allocation
#include <stdio.h>
#include <stdlib.h>

// Define structure
struct Satellite {
    char name[50];
    char launchVehicle[50];
    int launchYear;
    float missionDuration;      // in years
    float successRate;          // percentage
};

// Function to display all satellites
void displaySatellites(struct Satellite *s, int n) {
    printf("\n--- Satellite Records ---\n");
    for(int i = 0; i < n; i++) {
        printf("\nSatellite %d\n", i + 1);
        printf("Name            : %s\n", s[i].name);
        printf("Launch Vehicle  : %s\n", s[i].launchVehicle);
        printf("Launch Year     : %d\n", s[i].launchYear);
        printf("Mission Duration: %.2f years\n", s[i].missionDuration);
        printf("Success Rate    : %.2f%%\n", s[i].successRate);
    }
}

// Function to find highest success rate satellite
void highestSuccess(struct Satellite *s, int n) {
    int index = 0;

    for(int i = 1; i < n; i++) {
        if(s[i].successRate > s[index].successRate) {
            index = i;
        }
    }

    printf("\n--- Top Performing Satellite ---\n");
    printf("Name         : %s\n", s[index].name);
    printf("Success Rate : %.2f%%\n", s[index].successRate);
}

// Function to display satellites launched in 2015
void launchedIn2015(struct Satellite *s, int n) {
    int found = 0;
    printf("\n--- Satellites Launched in 2015 ---\n");

    for(int i = 0; i < n; i++) {
        if(s[i].launchYear == 2015) {
            printf("\nName           : %s\n", s[i].name);
            printf("Launch Vehicle : %s\n", s[i].launchVehicle);
            printf("Success Rate   : %.2f%%\n", s[i].successRate);
            found = 1;
        }
    }

    if(!found) {
        printf("No satellites found for the year 2015.\n");
    }
}

int main() {
    int n;

    printf("Enter number of satellites: ");
    scanf("%d", &n);

    // Dynamic memory allocation
    struct Satellite *sat = (struct Satellite*)malloc(n * sizeof(struct Satellite));

    if(sat == NULL) {
        printf("Memory allocation failed!\n");
        return 1;
    }

    // Input satellite details
    for(int i = 0; i < n; i++) {
        printf("\nEnter details for Satellite %d\n", i + 1);

        printf("Name: ");
        scanf(" %[^\n]", sat[i].name);

        printf("Launch Vehicle: ");
        scanf(" %[^\n]", sat[i].launchVehicle);

        printf("Launch Year: ");
        scanf("%d", &sat[i].launchYear);

        printf("Mission Duration (years): ");
        scanf("%f", &sat[i].missionDuration);

        printf("Success Rate (%%): ");
        scanf("%f", &sat[i].successRate);
    }

    // Function calls
    displaySatellites(sat, n);
    highestSuccess(sat, n);
    launchedIn2015(sat, n);

    // Free allocated memory
    free(sat);

    return 0;
}
