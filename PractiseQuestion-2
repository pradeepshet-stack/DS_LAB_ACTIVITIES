A leading automobile company, Tata Motors, wants to analyze its annual car sales data to evaluate performance and support future business strategies.
To efficiently manage and analyze car sales information, the company plans to develop a system with the following requirements:
Read the details of N cars using structures and dynamic memory allocation. Display all entered car records.

Implement separate functions to:

1. Find the Minimum Sales.
2. Find the Maximum Sales.
3. Calculate the Average Sales.
4. Display car model(s) released in the year 2010.
5. Sort the cars in ascending order of price.

Students must identify suitable data members and implement required functions.

✅ C Program (Structures + Dynamic Memory Allocation)
#include <stdio.h>
#include <stdlib.h>

// Structure definition
struct Car {
    char model[50];
    int releaseYear;
    float price;
    int sales;   // annual sales units
};

// Function to display all cars
void displayCars(struct Car *c, int n) {
    printf("\n--- Car Records ---\n");
    for(int i = 0; i < n; i++) {
        printf("\nCar %d\n", i + 1);
        printf("Model        : %s\n", c[i].model);
        printf("Release Year : %d\n", c[i].releaseYear);
        printf("Price        : %.2f\n", c[i].price);
        printf("Sales        : %d\n", c[i].sales);
    }
}

// Function to find minimum sales
void minSales(struct Car *c, int n) {
    int min = c[0].sales;
    for(int i = 1; i < n; i++) {
        if(c[i].sales < min)
            min = c[i].sales;
    }
    printf("\nMinimum Sales: %d\n", min);
}

// Function to find maximum sales
void maxSales(struct Car *c, int n) {
    int max = c[0].sales;
    for(int i = 1; i < n; i++) {
        if(c[i].sales > max)
            max = c[i].sales;
    }
    printf("Maximum Sales: %d\n", max);
}

// Function to find average sales
void avgSales(struct Car *c, int n) {
    int sum = 0;
    for(int i = 0; i < n; i++) {
        sum += c[i].sales;
    }
    printf("Average Sales: %.2f\n", (float)sum / n);
}

// Function to display cars released in 2010
void releasedIn2010(struct Car *c, int n) {
    int found = 0;
    printf("\n--- Cars Released in 2010 ---\n");
    for(int i = 0; i < n; i++) {
        if(c[i].releaseYear == 2010) {
            printf("Model: %s | Price: %.2f | Sales: %d\n",
                   c[i].model, c[i].price, c[i].sales);
            found = 1;
        }
    }
    if(!found)
        printf("No cars found released in 2010.\n");
}

// Function to sort cars by price (ascending)
void sortByPrice(struct Car *c, int n) {
    struct Car temp;
    for(int i = 0; i < n - 1; i++) {
        for(int j = i + 1; j < n; j++) {
            if(c[i].price > c[j].price) {
                temp = c[i];
                c[i] = c[j];
                c[j] = temp;
            }
        }
    }
    printf("\n--- Cars Sorted by Price (Ascending) ---\n");
    for(int i = 0; i < n; i++) {
        printf("Model: %s | Price: %.2f\n", c[i].model, c[i].price);
    }
}

int main() {
    int n;

    printf("Enter number of cars: ");
    scanf("%d", &n);

    // Dynamic memory allocation
    struct Car *car = (struct Car*)malloc(n * sizeof(struct Car));

    if(car == NULL) {
        printf("Memory allocation failed!\n");
        return 1;
    }

    // Input details
    for(int i = 0; i < n; i++) {
        printf("\nEnter details for Car %d\n", i + 1);

        printf("Model: ");
        scanf(" %[^\n]", car[i].model);

        printf("Release Year: ");
        scanf("%d", &car[i].releaseYear);

        printf("Price: ");
        scanf("%f", &car[i].price);

        printf("Sales: ");
        scanf("%d", &car[i].sales);
    }

    // Function calls
    displayCars(car, n);
    minSales(car, n);
    maxSales(car, n);
    avgSales(car, n);
    releasedIn2010(car, n);
    sortByPrice(car, n);

    // Free memory
    free(car);

    return 0;
}
